# ===== LOCO (Frontend) 환경변수 템플릿 =====
# 이 파일을 복사하여 .env로 이름 변경 후 실제 값을 입력하세요.
# cp .env.example .env

# ===== API 서버 =====
VITE_API_HOST=http://localhost:3000

# ===== Socket.IO =====
VITE_API_SOCKET=http://localhost:3000

# ===== 카카오 SDK =====
VITE_KAKAO_JS_KEY=your_kakao_js_key
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth/callback

# ===== 네이버 OAuth =====
VITE_NAVER_CLIENT_ID=your_naver_client_id
VITE_NAVER_REDIRECT_URI=http://localhost:5173/auth/naver/callback

# ===== 포트원 본인인증 =====
VITE_PORTONE_STORE_ID=your_portone_store_id
VITE_PORTONE_CHANNEL_KEY=your_portone_channel_key

# ===== 기본 프로필 이미지 =====
VITE_DEFAULT_PROFILE_IMAGE=data:image/jpeg;base64,...

# ===== 빌드 설정 =====
VITE_SOURCEMAP=false

# ===== localStorage 암호화 =====
VITE_STORAGE_SECRET_KEY=your_64char_hex_secret_key
